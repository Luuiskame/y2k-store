STORE_CORS=http://localhost:8000,https://docs.medusajs.com
ADMIN_CORS=http://localhost:5173,http://localhost:9000,https://docs.medusajs.com
AUTH_CORS=http://localhost:5173,http://localhost:9000,https://docs.medusajs.com
# Redis — required in production for cache, event bus, and workflow engine.
# Leave UNSET locally to use the in-memory fallbacks (fine for dev).
# Format: redis[s]://[user][:password]@host[:port][/db]
REDIS_URL=
JWT_SECRET=supersecret
COOKIE_SECRET=supersecret
DATABASE_URL=
DB_NAME=medusa-v2

# Cloudflare R2 (S3-compatible file storage)
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_FILE_URL=https://<your-public-r2-url-or-custom-domain>
