STORE_CORS=http://localhost:8000,https://docs.medusajs.com
ADMIN_CORS=http://localhost:5173,http://localhost:9000,https://docs.medusajs.com
AUTH_CORS=http://localhost:5173,http://localhost:9000,https://docs.medusajs.com
# Redis — required in production for cache, event bus, workflow engine, locking.
# Leave UNSET locally to use the in-memory fallbacks (fine for dev).
# Format: redis[s]://[user][:password]@host[:port][/db]
# On Railway, append ?family=0 to the internal URL so ioredis accepts IPv6.
REDIS_URL=
JWT_SECRET=supersecret
COOKIE_SECRET=supersecret
DATABASE_URL=
DB_NAME=medusa-v2

# Worker split — production runs two services (server + worker) sharing this repo.
# Local dev: leave unset (defaults to "shared" — single process does everything).
# Railway server service: MEDUSA_WORKER_MODE=server, DISABLE_MEDUSA_ADMIN=false
# Railway worker service: MEDUSA_WORKER_MODE=worker, DISABLE_MEDUSA_ADMIN=true
MEDUSA_WORKER_MODE=
DISABLE_MEDUSA_ADMIN=false
# Public URL of the deployed backend (used by the admin UI to know its own origin)
MEDUSA_BACKEND_URL=

# Cloudflare R2 (S3-compatible file storage)
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_FILE_URL=https://<your-public-r2-url-or-custom-domain>
